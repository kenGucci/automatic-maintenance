# NPM Configuration for Automatic Maintenance Project

# Use exact versions for production stability
save-exact=false

# Set registry to public npm registry (default)
registry=https://registry.npmjs.org/

# Allow scripts to run during installation
ignore-scripts=false

# Set install depth for dependency resolution
depth=0

# Create package-lock.json for reproducible installs
package-lock=true

# Enable audit and fund messages
audit=true
fund=true

# Set timeouts for slow networks
fetch-timeout=60000

# Use legacy peer deps resolution if needed (uncomment if you have peer dependency conflicts)
# legacy-peer-deps=false
