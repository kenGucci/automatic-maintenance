# Automatic Maintenance - Environment Configuration
# Copy this file to .env and fill in your values

# --- General ---
NODE_ENV=development
LOG_LEVEL=info

# --- Monitoring ---
MONITORING_INTERVAL=30000
AUTO_REMEDIATION=true
DASHBOARD_PORT=8080

# --- Alert Thresholds ---
# CPU_WARNING=70
# CPU_CRITICAL=90
# MEMORY_WARNING=75
# MEMORY_CRITICAL=95
# DISK_WARNING=80
# DISK_CRITICAL=95

# --- Slack Notifications ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# --- Email Notifications ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=automend@localhost
# EMAIL_TO=admin@example.com

# --- Remote Hosts (SSH) ---
# Comma-separated list of hostnames or IPs
# REMOTE_HOSTS=web-01,db-01,cache-01
# SSH_KEY_PATH=/path/to/id_rsa
# Per-host settings (replace dots/dashes with underscores):
# SSH_PORT_WEB_01=22
# SSH_USER_WEB_01=root

# --- Cloudflare ---
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# --- Sentry Error Tracking ---
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# --- OpenAI (for CrewAI agents) ---
# OPENAI_API_KEY=sk-...

# --- SerperDev (for CrewAI search tool) ---
# SERPER_API_KEY=your-serper-api-key
