# Automatic Maintenance - Environment Configuration
# Copy this file to .env and fill in your values

# --- General ---
NODE_ENV=development
LOG_LEVEL=info

# --- Monitoring ---
MONITORING_INTERVAL=30000
AUTO_REMEDIATION=true
DASHBOARD_PORT=8080

# --- Alert Thresholds ---
# (Configured via dashboard Settings page, or override here)
# CPU_WARNING=70
# CPU_CRITICAL=90
# MEMORY_WARNING=75
# MEMORY_CRITICAL=95
# DISK_WARNING=80
# DISK_CRITICAL=95

# --- Notifications ---
NOTIFICATION_CHANNELS=email,slack

# --- Slack Integration ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Email Integration ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ALERT_EMAIL_TO=alerts@yourdomain.com

# --- Cloudflare ---
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# --- OpenAI (for CrewAI agents) ---
# OPENAI_API_KEY=sk-...

# --- SerperDev (for CrewAI search tool) ---
# SERPER_API_KEY=your-serper-api-key

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_AUTHORIZED_USERS=your-chat-id-1,your-chat-id-2
DASHBOARD_URL=http://127.0.0.1:8080
